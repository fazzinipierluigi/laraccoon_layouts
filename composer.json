{
    "name": "fazzinipierluigi/laraccoon-layouts",
    "description": "Laravel package for saving and managing Raccoon Tables layouts",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Pierluigi Fazzini",
            "email": "gigif91@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Fazzinipierluigi\\LaraccoonLayouts\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fazzinipierluigi\\LaraccoonLayouts\\RaccoonLayoutsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
